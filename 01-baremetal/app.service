[Unit]
Description=Infra Tutorial Flask App
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/infra-tutorial/app
Environment=DEPLOY_ENV=baremetal
ExecStart=/opt/infra-tutorial/.venv/bin/gunicorn --bind 0.0.0.0:5000 --workers 4 app:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
